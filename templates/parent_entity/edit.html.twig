{% extends 'base.html.twig' %}

{% block title %} Modifier un parent{% endblock %}

{% block body %}
    <edit-parent
            :parent="{{ parent|json_encode }}"
            :students='{{ students|json_encode|raw }}'
            update-url="{{ path("api_parent_update", { id: parent.id }) }}"
            csrf-token="{{ csrf_token('edit_parent_' ~ parent.id) }}"
    ></edit-parent>
{% endblock %}